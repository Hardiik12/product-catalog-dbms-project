# Node.js Express Gateway Environment Variables Example
PORT=8000
SPRINGBOOT_URL=http://localhost:8080
FASTAPI_URL=http://localhost:5000
MONGO_URI=mongodb+srv://<USERNAME>:<PASSWORD>@<CLUSTER>.mongodb.net/?appName=productCatalog
MONGO_DB_NAME=product_catalog_ai
JWT_SECRET=your_super_secret_jwt_key_here
EMBEDDING_SIDECAR_URL=http://127.0.0.1:8001/embed
